  "Articles": [
    {
      "Id": 1,
      "Title": "\u041E\u0441\u043D\u043E\u0432\u0438 \u0440\u043E\u0431\u043E\u0442\u0438 \u0437 Avalonia UI \u0434\u043B\u044F \u0434\u0435\u0441\u043A\u0442\u043E\u043F\u0443",
      "Content": "Avalonia UI \u2014 \u0446\u0435 \u043F\u043E\u0442\u0443\u0436\u043D\u0438\u0439 \u0444\u0440\u0435\u0439\u043C\u0432\u043E\u0440\u043A \u0434\u043B\u044F \u0441\u0442\u0432\u043E\u0440\u0435\u043D\u043D\u044F \u043A\u0440\u043E\u0441\u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u043D\u0438\u0445 \u0437\u0430\u0441\u0442\u043E\u0441\u0443\u043D\u043A\u0456\u0432 \u043D\u0430 C#. \u0412\u0456\u043D \u0447\u0443\u0434\u043E\u0432\u043E \u043F\u0456\u0434\u0445\u043E\u0434\u0438\u0442\u044C \u0434\u043B\u044F \u0441\u0442\u0432\u043E\u0440\u0435\u043D\u043D\u044F \u0456\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0456\u0432, \u044F\u043A\u0456 \u043C\u0430\u044E\u0442\u044C \u043D\u0430\u0434\u0456\u0439\u043D\u043E \u043F\u0440\u0430\u0446\u044E\u0432\u0430\u0442\u0438 \u0432 \u043E\u0444\u043B\u0430\u0439\u043D-\u0440\u0435\u0436\u0438\u043C\u0456.",
      "CategoryId": 1,
      "AuthorId": 1
    },
    {
      "Id": 2,
      "Title": "Blazor WebAssembly: \u0412\u0440\u0430\u0436\u0435\u043D\u043D\u044F \u0432\u0456\u0434 \u0440\u043E\u0437\u0440\u043E\u0431\u043A\u0438",
      "Content": "\u0421\u044C\u043E\u0433\u043E\u0434\u043D\u0456 \u0445\u043E\u0447\u0443 \u043F\u043E\u0434\u0456\u043B\u0438\u0442\u0438\u0441\u044F \u0434\u043E\u0441\u0432\u0456\u0434\u043E\u043C \u0440\u043E\u0437\u0440\u043E\u0431\u043A\u0438 \u043D\u0430 Blazor WebAssembly. \u0426\u0435 \u0456\u0434\u0435\u0430\u043B\u044C\u043D\u0438\u0439 \u0456\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0435\u043D\u043D\u044F C# \u043B\u043E\u0433\u0456\u043A\u0438 \u0431\u0435\u0437\u043F\u043E\u0441\u0435\u0440\u0435\u0434\u043D\u044C\u043E \u0432 \u0431\u0440\u0430\u0443\u0437\u0435\u0440 \u043A\u043B\u0456\u0454\u043D\u0442\u0430.",
      "CategoryId": 1,
      "AuthorId": 1
    },
    {
      "Id": 3,
      "Title": "\u042F\u043A \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E \u0440\u043E\u0437\u0440\u0430\u0445\u0443\u0432\u0430\u0442\u0438 \u0431\u0456\u043B\u043E\u043A \u0434\u043B\u044F \u043D\u0430\u0431\u043E\u0440\u0443 \u043C\u0430\u0441\u0438",
      "Content": "\u041F\u0456\u0434 \u0447\u0430\u0441 \u043F\u0435\u0440\u0456\u043E\u0434\u0443 \u043D\u0430\u0431\u043E\u0440\u0443 \u043C\u0430\u0441\u0438 \u0430\u0431\u043E \u0441\u0443\u0448\u043A\u0438, \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C \u043F\u0440\u043E\u0442\u0435\u0457\u043D\u0443 \u0454 \u043A\u0440\u0438\u0442\u0438\u0447\u043D\u043E \u0432\u0430\u0436\u043B\u0438\u0432\u0438\u043C. \u041D\u0435 \u0437\u0430\u0431\u0443\u0432\u0430\u0439\u0442\u0435 \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0432\u0430\u0442\u0438 \u0442\u0440\u0435\u043A\u0435\u0440\u0438 \u0434\u043B\u044F \u0442\u043E\u0447\u043D\u0438\u0445 \u043F\u043E\u043A\u0430\u0437\u043D\u0438\u043A\u0456\u0432.",
      "CategoryId": 2,
      "AuthorId": 2
    },
    {
      "Id": 4,
      "Title": "\u0427\u043E\u043C\u0443 \u0431\u043E\u0457\u0432\u043A\u0430 \u0432 Yakuza / Like a Dragon \u0443\u043D\u0456\u043A\u0430\u043B\u044C\u043D\u0430",
      "Content": "\u0421\u0435\u0440\u0456\u044F \u0456\u0433\u043E\u0440 Yakuza \u0437\u0430\u0432\u0436\u0434\u0438 \u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044F \u0441\u0432\u043E\u0457\u043C \u043F\u0456\u0434\u0445\u043E\u0434\u043E\u043C \u0434\u043E \u0431\u043E\u0457\u0432. \u0412\u0456\u0434 \u043A\u043B\u0430\u0441\u0438\u0447\u043D\u043E\u0433\u043E brawler \u0434\u043E \u043F\u043E\u043A\u0440\u043E\u043A\u043E\u0432\u0438\u0445 RPG-\u0435\u043B\u0435\u043C\u0435\u043D\u0442\u0456\u0432 \u0443 \u043D\u043E\u0432\u0438\u0445 \u0447\u0430\u0441\u0442\u0438\u043D\u0430\u0445 \u2014 \u0446\u0435 \u0437\u0430\u0431\u0435\u0437\u043F\u0435\u0447\u0443\u0454 \u043D\u0435\u0439\u043C\u043E\u0432\u0456\u0440\u043D\u0443 \u0434\u0438\u043D\u0430\u043C\u0456\u043A\u0443.",
      "CategoryId": 3,
      "AuthorId": 4
    },
    {
      "Id": 5,
      "Title": "Marvel Rivals: \u041A\u043E\u043C\u0430\u043D\u0434\u043D\u0430 \u0441\u0438\u043D\u0435\u0440\u0433\u0456\u044F",
